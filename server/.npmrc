# ==========================================
# npm 配置文件 (.npmrc)
# ==========================================

# 1. 默认源设置 (官方源)
# 这是 npm 的默认官方仓库地址
# registry=https://registry.npmjs.org/

# 2. 淘宝镜像源 (已注释)
# 如果您需要在国内加速下载，可以删除下方行首的 '#' 符号来启用它
registry=https://registry.npmmirror.com/

# ==========================================
# 其他常用配置 (可选)
# ==========================================

# 允许不安全的 http 请求 (内网或特定私有源可能需要)
# unsafe-perm=true

# 禁用严格的 SSL 证书验证 (解决部分自签名证书报错)
# strict-ssl=false

# 设置安装时的保存前缀 (~ 代表兼容版本，^ 代表允许小版本升级)
# save-prefix=~

# 是否启用进度条显示
# progress=true